 {
+#ifdef __APPLE__
+	end_cub3d(data);
+	exit(EXIT_SUCCESS);
+#else
 	mlx_loop_end(data->mlx);
+#endif
 	return (0);
 }
 
@@ -71,7 +76,9 @@ void	end_cub3d(t_cub3d *cub3d)
